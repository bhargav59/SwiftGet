{
  "manifest_version": 3,
  "name": "SwiftGet Download Manager",
  "version": "1.0.0",
  "description": "Intercept browser downloads and video streams, routing them through SwiftGet for accelerated downloading.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "SwiftGet"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "activeTab",
    "nativeMessaging",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "download_rules",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "options_page": "options.html",
  "externally_connectable": {
    "matches": ["<all_urls>"]
  }
}
